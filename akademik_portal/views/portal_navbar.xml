<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ═══════════════════════════════════════════════
         Inject Akademik nav into Odoo's native portal
         navbar by extending placeholder_user_sign_in
         (called inside #top_menu ul)
    ═══════════════════════════════════════════════ -->
    <template id="portal_akademik_top_menu"
              inherit_id="portal.placeholder_user_sign_in"
              name="Akademik Portal Top Menu">
        <xpath expr="." position="inside">
            <t t-nocache="nim check is user-specific"
               t-if="not request.env.user._is_public() and request.env.user.partner_id.nim">
                <li class="nav-item">
                    <a class="nav-link fw-semibold px-3" href="/my/akademik/">Profil</a>
                </li>
                <li class="nav-item dropdown">
                    <a class="nav-link dropdown-toggle fw-semibold px-3" href="#"
                       role="button" data-bs-toggle="dropdown">KRS</a>
                    <ul class="dropdown-menu shadow-sm border-0 rounded-3">
                        <li><a class="dropdown-item py-2" href="/my/akademik/krs/">📋 KRS List</a></li>
                        <li><a class="dropdown-item py-2" href="/my/akademik/jadwal/">📅 Class Schedule</a></li>
                    </ul>
                </li>
                <li class="nav-item">
                    <a class="nav-link fw-semibold px-3" href="/my/akademik/tesis/">Tesis</a>
                </li>
                <li class="nav-item d-none d-lg-block">
                    <span class="nav-link text-muted px-2 disabled">|</span>
                </li>
            </t>
        </xpath>
    </template>

    <template id="akademik_my_account_link" inherit_id="portal.my_account_link" name="Direct to Security for Students">
        <xpath expr="//a[@href='/my/home']" position="attributes">
            <attribute name="href">/my/security</attribute>
        </xpath>
    </template>
</odoo>
