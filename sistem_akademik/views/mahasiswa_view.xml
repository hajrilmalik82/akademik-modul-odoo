<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_partner_tree_mahasiswa" model="ir.ui.view">
        <field name="name">res.partner.tree.mahasiswa</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <tree string="Student">
                <field name="image_128" widget="image"/>
                <field name="nim"/>
                <field name="name"/>
                <field name="study_program_id"/>
                <field name="entry_year_id"/>
                <field name="student_tags" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="email" widget="email"/>
                <field name="phone" widget="phone"/>
                <field name="research_topic"/>
                <field name="supervisor_id"/>
                <field name="achievement_level" widget="priority"/>
                <field name="status" widget="badge" decoration-success="status == 'graduated'" decoration-danger="status == 'dropout'"/>
            </tree>
        </field>
    </record>

    <record id="view_partner_form_inherit_akademik" model="ir.ui.view">
        <field name="name">res.partner.form.inherit.akademik</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!-- Inject Header before sheet -->
            <xpath expr="//sheet" position="before">
                <header invisible="not is_student">
                    <button name="action_generate_nim" string="Generate NIM" type="object" class="oe_highlight" invisible="nim"/>
                    <button name="action_generate_portal_user"
                            string="Generate Portal User"
                            type="object"
                            class="btn-secondary"
                            groups="sistem_akademik.group_akademik_officer"
                            invisible="user_ids"/>
                    <field name="status" widget="statusbar" statusbar_visible="draft,active,graduated,dropout" options="{'clickable': '1'}"/>
                </header>
            </xpath>
            
            <!-- Hide some standard elements logically if needed, but let's just add our fields -->
            <xpath expr="//field[@name='category_id']" position="after">
                <field name="is_student" invisible="1"/>
                <field name="user_ids" invisible="1"/>
                <field name="nim" invisible="not is_student" readonly="1"/>
                <field name="study_program_id" invisible="not is_student" readonly="not context.get('uid_is_officer', False)"/>
                <field name="student_tags" widget="many2many_tags" options="{'color_field': 'color'}" invisible="not is_student"/>
            </xpath>

            <!-- Academic Data Notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="Academic Data" invisible="not is_student">
                    <group>
                        <field name="research_topic"/>
                        <field name="supervisor_id" readonly="1"/>
                        <field name="achievement_level" widget="priority"/>
                        <field name="entry_year_id" readonly="not context.get('uid_is_officer', False)"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <record id="view_mahasiswa_search" model="ir.ui.view">
        <field name="name">res.partner.search.mahasiswa</field>
        <field name="model">res.partner</field>
        <field name="arch" type="xml">
            <search string="Student Search">
                <field name="name" string="Name" filter_domain="['|', '|', ('name', 'ilike', self), ('nim', 'ilike', self), ('email', 'ilike', self)]"/>
                <field name="nim" string="NIM"/>
                <field name="email" string="Email"/>
                
                <separator/>
                <filter string="Active Student" name="filter_aktif" domain="[('status', '=', 'active')]"/>
                <filter string="Graduated" name="filter_lulus" domain="[('status', '=', 'graduated')]"/>
                <filter string="Dropped Out" name="filter_dropout" domain="[('status', '=', 'dropout')]"/>
                
                <group expand="0" string="Group By">
                    <filter string="Study Program" name="group_prodi" context="{'group_by': 'study_program_id'}"/>
                </group>
                <searchpanel>
                    <field name="study_program_id" icon="fa-building" enable_counters="1"/>
                    <field name="status" icon="fa-tags" enable_counters="1"/>
                </searchpanel>
            </search>
        </field>
    </record>

    <record id="action_mahasiswa_list" model="ir.actions.act_window">
        <field name="name">Student</field>
        <field name="res_model">res.partner</field>
        <field name="view_mode">tree,form</field>
        <field name="view_id" ref="view_partner_tree_mahasiswa"/>
        <field name="search_view_id" ref="view_mahasiswa_search"/>
        <field name="domain">[('is_student', '=', True)]</field>
        <!-- Removing form_view_ref to fallback to the inherited base partner form -->
        <field name="context">{'default_is_student': True, 'uid_is_officer': True, 'tree_view_ref': 'sistem_akademik.view_partner_tree_mahasiswa'}</field>
    </record>

</odoo>
